# Copy to .env and fill in ONE provider key to use a real LLM (optional).
# With no key set, the agent runs fully offline with a deterministic mock encoder.

# --- Provider selection (optional; default "auto" = use whichever key is present) ---
# RADAR_LLM_PROVIDER=auto        # auto | anthropic | openai | mock

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# RADAR_LLM_MODEL=claude-haiku-4-5-20251001

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# RADAR_LLM_MODEL=gpt-4o-mini
